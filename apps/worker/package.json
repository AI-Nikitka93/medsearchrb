{
  "name": "medsearchrb-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "catalog:audit": "tsx ./scripts/catalog-quality-audit.ts",
    "catalog:backfill": "tsx ./scripts/backfill-from-batch.ts",
    "catalog:remediate": "tsx ./scripts/catalog-remediate.ts",
    "catalog:sanitize": "tsx ./scripts/catalog-sanitize.ts",
    "check": "tsc --noEmit",
    "clinics:health": "tsx ./scripts/clinic-site-health-sync.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "node ./scripts/apply-migrations.mjs",
    "promo:coverage": "tsx ./scripts/promo-coverage-audit.ts",
    "promo:priority": "tsx ./scripts/promo-priority-report.ts",
    "promo:web-verify": "tsx ./scripts/promo-web-verify.ts",
    "verify:clinics": "tsx ./scripts/verify-clinic-sites.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "wrangler": "^4.76.0"
  }
}
